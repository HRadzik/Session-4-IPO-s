#input phase
lname = input("Enter last name: ")
num_dependents = int(input("Enter number of dependents: "))
gross_income = float(input("Enter gross income: "))
#procces phase
adjusted_gross = gross_income - (num_dependents * 12000)
if adjusted_gross > 50000: tax_rate = 0.20
else: tax_rate = 0.10
income_tax = adjusted_gross * tax_rate
if income_tax < 0: income_tax = 100.0
#output phase
print("Last name:", lname)
print("Gross income: $", format(gross_income, ".2f"))
print("Number of dependents:", num_dependents)
print("Adjusted gross income: $", format(adjusted_gross, ".2f"))
print("Income tax: $", format(income_tax, ".2f"))
